{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://open330.github.io/air/schema/1.0.0/trace.schema.json",
  "title": "AIR 1 trace profiles",
  "allOf": [
    {
      "$ref": "https://open330.github.io/air/schema/1.0.0/air.schema.json#/$defs/envelope"
    },
    {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "kind": {
              "const": "trace"
            },
            "profile": {
              "const": "https://open330.github.io/air/profiles/1.0.0/trace-native-run"
            },
            "body": {
              "$ref": "#/$defs/nativeTraceBody"
            }
          }
        },
        {
          "type": "object",
          "properties": {
            "kind": {
              "const": "trace"
            },
            "profile": {
              "const": "https://open330.github.io/air/profiles/1.0.0/trace-session-snapshot"
            },
            "body": {
              "$ref": "#/$defs/sessionTraceBody"
            }
          }
        }
      ]
    }
  ],
  "unevaluatedProperties": false,
  "$defs": {
    "adapter": {
      "type": "object",
      "required": [
        "id",
        "version"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 256
        },
        "version": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        }
      },
      "unevaluatedProperties": false
    },
    "eventEdge": {
      "type": "object",
      "required": [
        "id",
        "from",
        "to",
        "kind",
        "assertion",
        "confidence",
        "evidence_refs"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 256
        },
        "from": {
          "type": "string",
          "minLength": 1,
          "maxLength": 256
        },
        "to": {
          "type": "string",
          "minLength": 1,
          "maxLength": 256
        },
        "kind": {
          "enum": [
            "provider-link",
            "temporal"
          ]
        },
        "assertion": {
          "enum": [
            "observed",
            "inferred"
          ]
        },
        "confidence": {
          "$ref": "https://open330.github.io/air/schema/1.0.0/air.schema.json#/$defs/confidence"
        },
        "evidence_refs": {
          "type": "array",
          "maxItems": 1000,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 256
          }
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "kind": {
                "const": "provider-link"
              }
            },
            "required": [
              "kind"
            ]
          },
          "then": {
            "properties": {
              "assertion": {
                "const": "observed"
              }
            }
          },
          "else": {
            "properties": {
              "assertion": {
                "const": "inferred"
              }
            }
          }
        }
      ],
      "unevaluatedProperties": false
    },
    "eventGraph": {
      "type": "object",
      "required": [
        "entry_event_ids",
        "nodes",
        "edges"
      ],
      "properties": {
        "entry_event_ids": {
          "type": "array",
          "maxItems": 30000,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 256
          }
        },
        "nodes": {
          "type": "array",
          "maxItems": 30000,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 256
          }
        },
        "edges": {
          "type": "array",
          "maxItems": 30000,
          "items": {
            "$ref": "#/$defs/eventEdge"
          }
        }
      },
      "unevaluatedProperties": false
    },
    "sessionEventEdge": {
      "allOf": [
        {
          "$ref": "#/$defs/eventEdge"
        },
        {
          "if": {
            "properties": {
              "kind": {
                "const": "provider-link"
              }
            },
            "required": [
              "kind"
            ]
          },
          "then": {
            "properties": {
              "confidence": {
                "type": "object",
                "required": [
                  "level",
                  "rule_id",
                  "reason"
                ],
                "properties": {
                  "level": {
                    "const": "explicit"
                  },
                  "rule_id": {
                    "const": "session.provider-link"
                  },
                  "reason": {
                    "const": "A provider-declared parent link was observed."
                  }
                },
                "unevaluatedProperties": false
              },
              "evidence_refs": {
                "maxItems": 0
              }
            }
          },
          "else": {
            "properties": {
              "confidence": {
                "type": "object",
                "required": [
                  "level",
                  "rule_id",
                  "reason"
                ],
                "properties": {
                  "level": {
                    "const": "structural"
                  },
                  "rule_id": {
                    "const": "session.file-order"
                  },
                  "reason": {
                    "const": "Only newline record order is inferred."
                  }
                },
                "unevaluatedProperties": false
              },
              "evidence_refs": {
                "maxItems": 0
              }
            }
          }
        },
        {
          "properties": {
            "id": {
              "pattern": "^edge_[A-Za-z0-9_-]{22}$"
            }
          }
        }
      ]
    },
    "sessionEventGraph": {
      "type": "object",
      "required": [
        "entry_event_ids",
        "nodes",
        "edges"
      ],
      "properties": {
        "entry_event_ids": {
          "type": "array",
          "maxItems": 30000,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 256,
            "pattern": "^event_[A-Za-z0-9_-]{22}$"
          }
        },
        "nodes": {
          "type": "array",
          "maxItems": 30000,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 256,
            "pattern": "^event_[A-Za-z0-9_-]{22}$"
          }
        },
        "edges": {
          "type": "array",
          "maxItems": 30000,
          "items": {
            "$ref": "#/$defs/sessionEventEdge"
          }
        }
      },
      "unevaluatedProperties": false
    },
    "nativeEvent": {
      "type": "object",
      "required": [
        "id",
        "order",
        "type",
        "status",
        "assertion",
        "confidence",
        "evidence_refs",
        "source"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 256
        },
        "order": {
          "type": "integer",
          "minimum": 0,
          "maximum": 29999
        },
        "type": {
          "type": "string",
          "minLength": 1,
          "maxLength": 256
        },
        "status": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        },
        "assertion": {
          "const": "observed"
        },
        "confidence": {
          "$ref": "https://open330.github.io/air/schema/1.0.0/air.schema.json#/$defs/confidence"
        },
        "evidence_refs": {
          "type": "array",
          "maxItems": 0,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 256
          }
        },
        "source": {
          "type": "object"
        }
      },
      "unevaluatedProperties": false
    },
    "failure": {
      "type": "object",
      "required": [
        "kind"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "minLength": 1,
          "maxLength": 256
        },
        "message": {
          "type": "string",
          "maxLength": 4096
        }
      },
      "unevaluatedProperties": false
    },
    "terminal": {
      "type": "object",
      "required": [
        "status",
        "completeness"
      ],
      "properties": {
        "status": {
          "enum": [
            "completed",
            "failed",
            "cancelled",
            "protocol-error",
            "truncated"
          ]
        },
        "completeness": {
          "enum": [
            "complete",
            "partial"
          ]
        },
        "failure": {
          "$ref": "#/$defs/failure"
        }
      },
      "unevaluatedProperties": false
    },
    "process": {
      "type": "object",
      "required": [
        "exit_code",
        "signal",
        "stderr",
        "stdout_bytes"
      ],
      "properties": {
        "exit_code": {
          "type": [
            "integer",
            "null"
          ]
        },
        "signal": {
          "type": [
            "string",
            "null"
          ]
        },
        "stderr": {
          "$ref": "https://open330.github.io/air/schema/1.0.0/air.schema.json#/$defs/byteRecord"
        },
        "stdout_bytes": {
          "type": "integer",
          "minimum": 0,
          "maximum": 33554432
        }
      },
      "unevaluatedProperties": false
    },
    "nativeTraceBody": {
      "type": "object",
      "required": [
        "workflow_content_digest",
        "plan_content_digest",
        "agent",
        "cwd",
        "safety",
        "adapter",
        "events",
        "event_graph",
        "process",
        "terminal",
        "diagnostics",
        "hidden_reasoning_recovered"
      ],
      "properties": {
        "workflow_content_digest": {
          "$ref": "https://open330.github.io/air/schema/1.0.0/air.schema.json#/$defs/sha256"
        },
        "plan_content_digest": {
          "$ref": "https://open330.github.io/air/schema/1.0.0/air.schema.json#/$defs/sha256"
        },
        "agent": {
          "enum": [
            "codex",
            "claude"
          ]
        },
        "cwd": {
          "$ref": "https://open330.github.io/air/schema/1.0.0/air.schema.json#/$defs/locator"
        },
        "safety": {
          "$ref": "https://open330.github.io/air/schema/1.0.0/plan.schema.json#/$defs/safety"
        },
        "adapter": {
          "$ref": "#/$defs/adapter"
        },
        "events": {
          "type": "array",
          "maxItems": 30000,
          "items": {
            "$ref": "#/$defs/nativeEvent"
          }
        },
        "event_graph": {
          "$ref": "#/$defs/eventGraph"
        },
        "process": {
          "$ref": "#/$defs/process"
        },
        "terminal": {
          "$ref": "#/$defs/terminal"
        },
        "diagnostics": {
          "type": "array",
          "maxItems": 10000,
          "items": {
            "$ref": "https://open330.github.io/air/schema/1.0.0/air.schema.json#/$defs/diagnostic"
          }
        },
        "hidden_reasoning_recovered": {
          "const": false
        }
      },
      "unevaluatedProperties": false
    },
    "sessionEvidence": {
      "type": "object",
      "required": [
        "raw_type",
        "top_level_keys",
        "byte_range",
        "byte_length",
        "sha256",
        "omitted"
      ],
      "properties": {
        "raw_type": {
          "enum": [
            "session.started",
            "turn.context-observed",
            "turn.input-observed",
            "turn.output-observed",
            "turn.item-observed",
            "turn.progress-observed",
            "turn.summary-observed",
            "record.observed",
            "record.malformed-omitted",
            "record.structure-omitted",
            "record.oversized-omitted"
          ]
        },
        "top_level_keys": {
          "type": "array",
          "minItems": 1,
          "maxItems": 1,
          "uniqueItems": true,
          "prefixItems": [
            {
              "const": "content-omitted"
            }
          ]
        },
        "byte_range": {
          "$ref": "https://open330.github.io/air/schema/1.0.0/air.schema.json#/$defs/byteRange"
        },
        "byte_length": {
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991
        },
        "sha256": {
          "$ref": "https://open330.github.io/air/schema/1.0.0/air.schema.json#/$defs/sha256"
        },
        "omitted": {
          "const": true
        }
      },
      "unevaluatedProperties": false
    },
    "sessionEvent": {
      "type": "object",
      "required": [
        "id",
        "order",
        "type",
        "assertion",
        "confidence",
        "evidence_refs",
        "evidence"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^event_[A-Za-z0-9_-]{22}$"
        },
        "order": {
          "type": "integer",
          "minimum": 0,
          "maximum": 29999
        },
        "type": {
          "enum": [
            "session.started",
            "turn.context-observed",
            "turn.input-observed",
            "turn.output-observed",
            "turn.item-observed",
            "turn.progress-observed",
            "turn.summary-observed",
            "record.observed",
            "record.malformed-omitted",
            "record.structure-omitted",
            "record.oversized-omitted"
          ]
        },
        "assertion": {
          "const": "observed"
        },
        "confidence": {
          "type": "object",
          "required": [
            "level",
            "rule_id",
            "reason"
          ],
          "properties": {
            "level": {
              "const": "explicit"
            },
            "rule_id": {
              "const": "session.complete-jsonl-line"
            },
            "reason": {
              "const": "A complete newline-delimited source record was observed."
            }
          },
          "unevaluatedProperties": false
        },
        "evidence_refs": {
          "type": "array",
          "maxItems": 0,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 256
          }
        },
        "evidence": {
          "type": "array",
          "minItems": 1,
          "maxItems": 1,
          "items": {
            "$ref": "#/$defs/sessionEvidence"
          }
        }
      },
      "unevaluatedProperties": false
    },
    "capture": {
      "type": "object",
      "required": [
        "adapter",
        "source_schema_fingerprint",
        "snapshot_cursor",
        "completeness",
        "source_prefix"
      ],
      "properties": {
        "adapter": {
          "allOf": [
            {
              "$ref": "#/$defs/adapter"
            },
            {
              "type": "object",
              "properties": {
                "id": {
                  "enum": [
                    "codex-rollout-jsonl",
                    "claude-project-jsonl"
                  ]
                },
                "version": {
                  "const": "1.0.0"
                }
              }
            }
          ],
          "unevaluatedProperties": false
        },
        "source_schema_fingerprint": {
          "$ref": "https://open330.github.io/air/schema/1.0.0/air.schema.json#/$defs/sha256"
        },
        "snapshot_cursor": {
          "type": "object",
          "required": [
            "epoch",
            "byte_offset"
          ],
          "properties": {
            "epoch": {
              "type": "integer",
              "minimum": 0
            },
            "byte_offset": {
              "type": "integer",
              "minimum": 0
            }
          },
          "unevaluatedProperties": false
        },
        "completeness": {
          "enum": [
            "complete-prefix",
            "partial-prefix",
            "truncated"
          ]
        },
        "source_prefix": {
          "type": "object",
          "required": [
            "byte_length",
            "sha256"
          ],
          "properties": {
            "byte_length": {
              "type": "integer",
              "minimum": 0,
              "maximum": 33554432
            },
            "sha256": {
              "$ref": "https://open330.github.io/air/schema/1.0.0/air.schema.json#/$defs/sha256"
            }
          },
          "unevaluatedProperties": false
        }
      },
      "unevaluatedProperties": false
    },
    "privacy": {
      "type": "object",
      "required": [
        "profile",
        "redaction_manifest"
      ],
      "properties": {
        "profile": {
          "const": "metadata-only"
        },
        "redaction_manifest": {
          "type": "array",
          "minItems": 15,
          "maxItems": 15,
          "prefixItems": [
            {
              "properties": {
                "category": {
                  "const": "prompt"
                }
              }
            },
            {
              "properties": {
                "category": {
                  "const": "message"
                }
              }
            },
            {
              "properties": {
                "category": {
                  "const": "reasoning"
                }
              }
            },
            {
              "properties": {
                "category": {
                  "const": "command"
                }
              }
            },
            {
              "properties": {
                "category": {
                  "const": "arguments"
                }
              }
            },
            {
              "properties": {
                "category": {
                  "const": "results"
                }
              }
            },
            {
              "properties": {
                "category": {
                  "const": "stdout"
                }
              }
            },
            {
              "properties": {
                "category": {
                  "const": "stderr"
                }
              }
            },
            {
              "properties": {
                "category": {
                  "const": "attachments"
                }
              }
            },
            {
              "properties": {
                "category": {
                  "const": "file-content"
                }
              }
            },
            {
              "properties": {
                "category": {
                  "const": "environment"
                }
              }
            },
            {
              "properties": {
                "category": {
                  "const": "credentials"
                }
              }
            },
            {
              "properties": {
                "category": {
                  "const": "paths"
                }
              }
            },
            {
              "properties": {
                "category": {
                  "const": "branches"
                }
              }
            },
            {
              "properties": {
                "category": {
                  "const": "provider-identifiers"
                }
              }
            }
          ],
          "items": {
            "type": "object",
            "required": [
              "category",
              "disposition"
            ],
            "properties": {
              "category": {
                "enum": [
                  "prompt",
                  "message",
                  "reasoning",
                  "command",
                  "arguments",
                  "results",
                  "stdout",
                  "stderr",
                  "attachments",
                  "file-content",
                  "environment",
                  "credentials",
                  "paths",
                  "branches",
                  "provider-identifiers"
                ]
              },
              "disposition": {
                "const": "omitted"
              },
              "count": {
                "type": "integer",
                "minimum": 0
              }
            },
            "unevaluatedProperties": false
          }
        }
      },
      "unevaluatedProperties": false
    },
    "lifecycleEvidence": {
      "type": "object",
      "required": [
        "source",
        "signal",
        "observed",
        "confidence"
      ],
      "properties": {
        "source": {
          "const": "process-liveness"
        },
        "signal": {
          "enum": [
            "process-identity-verified-active",
            "process-identity-verified-idle"
          ]
        },
        "observed": {
          "const": true
        },
        "confidence": {
          "type": "object",
          "required": [
            "level",
            "rule_id",
            "reason"
          ],
          "properties": {
            "level": {
              "const": "explicit"
            },
            "rule_id": {
              "const": "session.process-identity"
            },
            "reason": {
              "const": "Provider-specific process evidence was verified."
            }
          },
          "unevaluatedProperties": false
        }
      },
      "unevaluatedProperties": false
    },
    "lifecycle": {
      "type": "object",
      "required": [
        "state",
        "complete",
        "confidence",
        "evidence"
      ],
      "properties": {
        "state": {
          "enum": [
            "active",
            "idle",
            "unknown"
          ]
        },
        "complete": {
          "const": false
        },
        "confidence": {
          "oneOf": [
            {
              "type": "object",
              "required": [
                "level",
                "rule_id",
                "reason"
              ],
              "properties": {
                "level": {
                  "const": "explicit"
                },
                "rule_id": {
                  "const": "session.process-identity"
                },
                "reason": {
                  "const": "Process identity and start identity were verified."
                }
              },
              "unevaluatedProperties": false
            },
            {
              "type": "object",
              "required": [
                "level",
                "rule_id",
                "reason"
              ],
              "properties": {
                "level": {
                  "const": "unknown"
                },
                "rule_id": {
                  "const": "session.lifecycle-unavailable"
                },
                "reason": {
                  "const": "No authoritative provider lifecycle evidence is available."
                }
              },
              "unevaluatedProperties": false
            }
          ]
        },
        "evidence": {
          "type": "array",
          "maxItems": 1,
          "items": {
            "$ref": "#/$defs/lifecycleEvidence"
          }
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "state": {
                "const": "unknown"
              }
            },
            "required": [
              "state"
            ]
          },
          "then": {
            "properties": {
              "confidence": {
                "properties": {
                  "level": {
                    "const": "unknown"
                  }
                }
              },
              "evidence": {
                "maxItems": 0
              }
            }
          },
          "else": {
            "properties": {
              "confidence": {
                "properties": {
                  "level": {
                    "const": "explicit"
                  }
                }
              },
              "evidence": {
                "minItems": 1,
                "maxItems": 1
              }
            }
          }
        }
      ],
      "unevaluatedProperties": false
    },
    "sessionTraceBody": {
      "type": "object",
      "required": [
        "capture",
        "privacy",
        "events",
        "event_graph",
        "lifecycle",
        "diagnostics",
        "hidden_reasoning_recovered"
      ],
      "properties": {
        "capture": {
          "$ref": "#/$defs/capture"
        },
        "privacy": {
          "$ref": "#/$defs/privacy"
        },
        "events": {
          "type": "array",
          "maxItems": 30000,
          "items": {
            "$ref": "#/$defs/sessionEvent"
          }
        },
        "event_graph": {
          "$ref": "#/$defs/sessionEventGraph"
        },
        "lifecycle": {
          "$ref": "#/$defs/lifecycle"
        },
        "diagnostics": {
          "type": "array",
          "maxItems": 10000,
          "items": {
            "type": "object",
            "required": [
              "severity",
              "code",
              "message",
              "targets"
            ],
            "properties": {
              "severity": {
                "enum": [
                  "info",
                  "warning"
                ]
              },
              "code": {
                "enum": [
                  "AIR_SESSION_TORN_SUFFIX_OMITTED",
                  "AIR_SESSION_SNAPSHOT_LIMIT",
                  "AIR_SESSION_OVERSIZED_RECORD_OMITTED"
                ]
              },
              "message": {
                "enum": [
